# URL de ton projet Supabase (Project Settings > API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Clé publique "anon" de ton projet Supabase (Project Settings > API)
VITE_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL publique où l'application sera accessible une fois déployée
# (utilisée pour générer les QR codes des clubs). En local, laisse la valeur ci-dessous.
VITE_PUBLIC_APP_URL=http://localhost:5173
